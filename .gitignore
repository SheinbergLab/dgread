# =============================================================================
# Build artifacts
# =============================================================================

# C compiled objects
*.o
*.obj
*.so
*.dylib
*.dll

# Python
*.pyc
*.pyd
__pycache__/
*.egg-info/
*.egg
build/
dist/
wheelhouse/
.eggs/

# MATLAB
*.mex*
*.asv

# R
*.Rcheck/
*.tar.gz
src/*.o
src/*.so
src/*.dll

# =============================================================================
# IDE and editor files
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Virtual environments
# =============================================================================
venv/
.venv/
env/
.env/

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# =============================================================================
# Data files (keep test fixtures)
# =============================================================================
*.dg
*.dgz
!tests/data/*.dgz

# =============================================================================
# Windows-specific build artifacts
# =============================================================================
*.lib
*.exp
*.pdb
*.ilk

# =============================================================================
# Archives (except releases)
# =============================================================================
*.zip
*.tar
*.gz
!tests/data/*
